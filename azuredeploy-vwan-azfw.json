{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "Espria-LZ-ARM-Builder",
      "version": "3.0.0"
    },
    "displayName": "Espria LZ \u2013 Variant B: Azure Virtual WAN + Azure Firewall",
    "description": "Deploys the Espria Azure Base Landing Zone using Azure Virtual WAN (Standard) with Azure Firewall Premium in secured virtual hubs. The vWAN Hub uses 10.{siteId}.0.0/23 \u2014 the same address block the connectivity VNet occupies in hub-spoke variants. vWAN routing intent replaces spoke UDRs. Optional vWAN VPN Gateway. IaaS Active Directory Domain Controllers. Azure Backup Enhanced Policy V2. Azure Site Recovery for the Management VM."
  },
  "parameters": {
    "customerName": {
      "type": "string",
      "metadata": {
        "description": "Customer full name (e.g. Contoso Ltd)"
      }
    },
    "customerAbbreviation": {
      "type": "string",
      "metadata": {
        "description": "3\u20135 character abbreviation used in all resource names (e.g. CON)"
      },
      "maxLength": 5
    },
    "customerDomainName": {
      "type": "string",
      "metadata": {
        "description": "Active Directory domain name (e.g. contoso.local)"
      }
    },
    "primaryRegion": {
      "type": "string",
      "metadata": {
        "description": "Primary Azure region for the Landing Zone"
      },
      "allowedValues": [
        "australiacentral",
        "australiacentral2",
        "australiaeast",
        "australiasoutheast",
        "brazilsouth",
        "brazilsoutheast",
        "canadacentral",
        "canadaeast",
        "centralindia",
        "centralus",
        "eastasia",
        "eastus",
        "eastus2",
        "francecentral",
        "francesouth",
        "germanynorth",
        "germanywestcentral",
        "israelcentral",
        "italynorth",
        "japaneast",
        "japanwest",
        "jioindiacentral",
        "jioindiawest",
        "koreacentral",
        "koreasouth",
        "mexicocentral",
        "newzealandnorth",
        "northcentralus",
        "northeurope",
        "norwayeast",
        "norwaywest",
        "polandcentral",
        "qatarcentral",
        "southafricanorth",
        "southafricawest",
        "southcentralus",
        "southeastasia",
        "southindia",
        "spaincentral",
        "swedencentral",
        "swedensouth",
        "switzerlandnorth",
        "switzerlandwest",
        "uaecentral",
        "uaenorth",
        "uksouth",
        "ukwest",
        "westcentralus",
        "westeurope",
        "westindia",
        "westus",
        "westus2",
        "westus3"
      ],
      "defaultValue": "uksouth"
    },
    "secondaryRegion": {
      "type": "string",
      "metadata": {
        "description": "Secondary Azure region. Set to \"auto\" to use the Microsoft-documented paired region."
      },
      "allowedValues": [
        "auto",
        "australiacentral",
        "australiacentral2",
        "australiaeast",
        "australiasoutheast",
        "brazilsouth",
        "brazilsoutheast",
        "canadacentral",
        "canadaeast",
        "centralindia",
        "centralus",
        "eastasia",
        "eastus",
        "eastus2",
        "francecentral",
        "francesouth",
        "germanynorth",
        "germanywestcentral",
        "israelcentral",
        "italynorth",
        "japaneast",
        "japanwest",
        "jioindiacentral",
        "jioindiawest",
        "koreacentral",
        "koreasouth",
        "mexicocentral",
        "newzealandnorth",
        "northcentralus",
        "northeurope",
        "norwayeast",
        "norwaywest",
        "polandcentral",
        "qatarcentral",
        "southafricanorth",
        "southafricawest",
        "southcentralus",
        "southeastasia",
        "southindia",
        "spaincentral",
        "swedencentral",
        "swedensouth",
        "switzerlandnorth",
        "switzerlandwest",
        "uaecentral",
        "uaenorth",
        "uksouth",
        "ukwest",
        "westcentralus",
        "westeurope",
        "westindia",
        "westus",
        "westus2",
        "westus3"
      ],
      "defaultValue": "auto"
    },
    "deploySecondaryRegion": {
      "type": "bool",
      "metadata": {
        "description": "Deploy resources into the secondary region. Set to false for primary-only."
      },
      "defaultValue": true
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Deployment environment."
      },
      "allowedValues": [
        "prod",
        "dev",
        "uat"
      ],
      "defaultValue": "prod"
    },
    "primaryRegionSiteId": {
      "type": "int",
      "metadata": {
        "description": "Primary region site ID (101\u2013199). Sets the 2nd octet of 10.x.0.0/16. The vWAN Hub will use 10.x.0.0/23 from this block."
      },
      "defaultValue": 101,
      "minValue": 101,
      "maxValue": 199
    },
    "secondaryRegionSiteId": {
      "type": "int",
      "metadata": {
        "description": "Secondary region site ID (101\u2013199). Sets the 2nd octet of 10.x.0.0/16."
      },
      "defaultValue": 102,
      "minValue": 101,
      "maxValue": 199
    },
    "primaryHubPrefix": {
      "type": "string",
      "metadata": {
        "description": "vWAN Hub address prefix for the primary region. Leave empty to auto-derive as 10.{primaryRegionSiteId}.0.0/23. Override only if a different range is required."
      },
      "defaultValue": ""
    },
    "secondaryHubPrefix": {
      "type": "string",
      "metadata": {
        "description": "vWAN Hub address prefix for the secondary region. Leave empty to auto-derive as 10.{secondaryRegionSiteId}.0.0/23."
      },
      "defaultValue": ""
    },
    "onPremAddressPrefix": {
      "type": "string",
      "metadata": {
        "description": "On-premises address prefix used in firewall rules (e.g. 10.1.0.0/16)."
      },
      "defaultValue": "10.1.0.0/16"
    },
    "firewallSkuTier": {
      "type": "string",
      "metadata": {
        "description": "Azure Firewall SKU tier. Premium enables IDPS and TLS inspection."
      },
      "allowedValues": [
        "Premium",
        "Standard"
      ],
      "defaultValue": "Premium"
    },
    "deployVpnGateway": {
      "type": "bool",
      "metadata": {
        "description": "Deploy a vWAN VPN Gateway in each hub. Adds approximately 30 minutes to provisioning time. Uses Microsoft.Network/vpnGateways (vWAN-native type)."
      },
      "defaultValue": false
    },
    "vpnGwScaleUnit": {
      "type": "int",
      "metadata": {
        "description": "vWAN VPN Gateway scale unit. 1 = 500 Mbps aggregate (active-active pair). Each additional unit adds 500 Mbps."
      },
      "defaultValue": 1,
      "minValue": 1,
      "maxValue": 20
    },
    "adminUsername": {
      "type": "string",
      "metadata": {
        "description": "Local administrator username for Domain Controller and Management VMs."
      },
      "defaultValue": "espria-admin"
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "VM admin password. Minimum 12 characters with upper, lower, number and symbol."
      }
    },
    "dcVmSize": {
      "type": "string",
      "metadata": {
        "description": "Domain Controller VM size."
      },
      "allowedValues": [
        "Standard_D2s_v4",
        "Standard_D4s_v4",
        "Standard_D8s_v4",
        "Standard_D2ds_v4",
        "Standard_D4ds_v4",
        "Standard_D8ds_v4",
        "Standard_D2as_v4",
        "Standard_D4as_v4",
        "Standard_D8as_v4",
        "Standard_D2s_v5",
        "Standard_D4s_v5",
        "Standard_D8s_v5",
        "Standard_D2ds_v5",
        "Standard_D4ds_v5",
        "Standard_D8ds_v5",
        "Standard_D2as_v5",
        "Standard_D4as_v5",
        "Standard_D8as_v5",
        "Standard_D2ads_v5",
        "Standard_D4ads_v5",
        "Standard_D8ads_v5",
        "Standard_D2s_v6",
        "Standard_D4s_v6",
        "Standard_D8s_v6"
      ],
      "defaultValue": "Standard_D2s_v5"
    },
    "mgmtVmSize": {
      "type": "string",
      "metadata": {
        "description": "Management jump VM size."
      },
      "allowedValues": [
        "Standard_B2ms",
        "Standard_B4ms",
        "Standard_B8ms",
        "Standard_D2s_v5",
        "Standard_D4s_v5"
      ],
      "defaultValue": "Standard_B2ms"
    },
    "createdBy": {
      "type": "string",
      "metadata": {
        "description": "Tag value for CreatedBy."
      },
      "defaultValue": "Espria"
    },
    "managedBy": {
      "type": "string",
      "metadata": {
        "description": "Tag value for ManagedBy."
      },
      "defaultValue": "Espria"
    },
    "alertEmailAddress": {
      "type": "string",
      "metadata": {
        "description": "Email address for Azure Monitor Action Group alerts."
      },
      "defaultValue": "alerts@espria.com"
    },
    "lawRetentionDays": {
      "type": "int",
      "metadata": {
        "description": "Log Analytics Workspace retention in days."
      },
      "defaultValue": 90,
      "minValue": 30,
      "maxValue": 730
    },
    "enableVmBackup": {
      "type": "bool",
      "metadata": {
        "description": "Enable Azure Backup Enhanced Policy V2 for DC VMs and the Management VM."
      },
      "defaultValue": true
    },
    "enableNvaDiskBackup": {
      "type": "bool",
      "metadata": {
        "description": "Enable NVA disk backup. Always false for this variant \u2013 no NVA is deployed."
      },
      "defaultValue": false
    },
    "enableAsrMgmtVm": {
      "type": "bool",
      "metadata": {
        "description": "Enable Azure Site Recovery A2A replication for the Management VM."
      },
      "defaultValue": true
    }
  },
  "variables": {
    "deploymentName": "[concat('espria-lz-vwan-azfw-', uniqueString(deployment().name))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "[variables('deploymentName')]",
      "location": "[parameters('primaryRegion')]",
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "Inner"
        },
        "parameters": {
          "customerName": {
            "value": "[parameters('customerName')]"
          },
          "customerAbbreviation": {
            "value": "[parameters('customerAbbreviation')]"
          },
          "customerDomainName": {
            "value": "[parameters('customerDomainName')]"
          },
          "primaryRegion": {
            "value": "[parameters('primaryRegion')]"
          },
          "secondaryRegion": {
            "value": "[parameters('secondaryRegion')]"
          },
          "deploySecondaryRegion": {
            "value": "[parameters('deploySecondaryRegion')]"
          },
          "environment": {
            "value": "[parameters('environment')]"
          },
          "primaryRegionSiteId": {
            "value": "[parameters('primaryRegionSiteId')]"
          },
          "secondaryRegionSiteId": {
            "value": "[parameters('secondaryRegionSiteId')]"
          },
          "primaryHubPrefix": {
            "value": "[parameters('primaryHubPrefix')]"
          },
          "secondaryHubPrefix": {
            "value": "[parameters('secondaryHubPrefix')]"
          },
          "onPremAddressPrefix": {
            "value": "[parameters('onPremAddressPrefix')]"
          },
          "firewallSkuTier": {
            "value": "[parameters('firewallSkuTier')]"
          },
          "deployVpnGateway": {
            "value": "[parameters('deployVpnGateway')]"
          },
          "vpnGwScaleUnit": {
            "value": "[parameters('vpnGwScaleUnit')]"
          },
          "adminUsername": {
            "value": "[parameters('adminUsername')]"
          },
          "adminPassword": {
            "value": "[parameters('adminPassword')]"
          },
          "dcVmSize": {
            "value": "[parameters('dcVmSize')]"
          },
          "mgmtVmSize": {
            "value": "[parameters('mgmtVmSize')]"
          },
          "createdBy": {
            "value": "[parameters('createdBy')]"
          },
          "managedBy": {
            "value": "[parameters('managedBy')]"
          },
          "alertEmailAddress": {
            "value": "[parameters('alertEmailAddress')]"
          },
          "lawRetentionDays": {
            "value": "[parameters('lawRetentionDays')]"
          },
          "enableVmBackup": {
            "value": "[parameters('enableVmBackup')]"
          },
          "enableNvaDiskBackup": {
            "value": "[parameters('enableNvaDiskBackup')]"
          },
          "enableAsrMgmtVm": {
            "value": "[parameters('enableAsrMgmtVm')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "customerName": {
              "type": "string"
            },
            "customerAbbreviation": {
              "type": "string"
            },
            "customerDomainName": {
              "type": "string"
            },
            "primaryRegion": {
              "type": "string"
            },
            "secondaryRegion": {
              "type": "string"
            },
            "deploySecondaryRegion": {
              "type": "bool"
            },
            "environment": {
              "type": "string"
            },
            "primaryRegionSiteId": {
              "type": "int"
            },
            "secondaryRegionSiteId": {
              "type": "int"
            },
            "primaryHubPrefix": {
              "type": "string"
            },
