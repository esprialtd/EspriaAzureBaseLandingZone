            "enableVmBackup": {
              "type": "bool"
            },
            "enableNvaDiskBackup": {
              "type": "bool"
            },
            "enableAsrMgmtVm": {
              "type": "bool"
            }
          },
          "resources": [],
          "outputs": {
            "deploymentNote": {
              "type": "string",
              "value": "[concat(\"Espria Azure Landing Zone (vwan-azfw) \u2013 full deployment managed via Bicep. Run az deployment sub create with variants/vwan-azfw/main.bicep for the complete deployment.\")]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "variantDeployed": {
      "type": "string",
      "value": "vwan-azfw"
    },
    "primaryRegion": {
      "type": "string",
      "value": "[parameters('primaryRegion')]"
    },
    "customerDeployed": {
      "type": "string",
      "value": "[parameters('customerName')]"
    },
    "vpnGatewayEnabled": {
      "type": "bool",
      "value": "[parameters('deployVpnGateway')]"
    }
  }
}