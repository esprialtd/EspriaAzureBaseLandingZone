              "type": "string"
            },
            "primaryRegion": {
              "type": "string"
            },
            "secondaryRegion": {
              "type": "string"
            },
            "deploySecondaryRegion": {
              "type": "bool"
            },
            "environment": {
              "type": "string"
            },
            "primaryRegionSiteId": {
              "type": "int"
            },
            "secondaryRegionSiteId": {
              "type": "int"
            },
            "onPremAddressPrefix": {
              "type": "string"
            },
            "adminUsername": {
              "type": "string"
            },
            "adminPassword": {
              "type": "securestring"
            },
            "dcVmSize": {
              "type": "string"
            },
            "mgmtVmSize": {
              "type": "string"
            },
            "createdBy": {
              "type": "string"
            },
            "managedBy": {
              "type": "string"
            },
            "alertEmailAddress": {
              "type": "string"
            },
            "lawRetentionDays": {
              "type": "int"
            },
            "enableVmBackup": {
              "type": "bool"
            },
            "enableAsrMgmtVm": {
              "type": "bool"
            },
            "sophosVmSize": {
              "type": "string"
            },
            "sophosImageVersion": {
              "type": "string"
            },
            "enableNvaDiskBackup": {
              "type": "bool"
            },
            "entraDsSku": {
              "type": "string"
            },
            "enableSecureLdap": {
              "type": "bool"
            }
          },
          "resources": [],
          "outputs": {
            "note": {
              "type": "string",
              "value": "Espria Azure Landing Zone (sophos-nva-entrads) \u2013 full deployment managed via Bicep. Run: az deployment sub create --template-file variants/sophos-nva-entrads/main.bicep"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "variantDeployed": {
      "type": "string",
      "value": "sophos-nva-entrads"
