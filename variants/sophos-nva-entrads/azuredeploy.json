        "uksouth",
        "ukwest",
        "westcentralus",
        "westeurope",
        "westindia",
        "westus",
        "westus2",
        "westus3"
      ],
      "defaultValue": "uksouth"
    },
    "secondaryRegion": {
      "type": "string",
      "metadata": {
        "description": "Secondary Azure region. \"auto\" = Microsoft-paired region."
      },
      "allowedValues": [
        "auto",
        "australiacentral",
        "australiacentral2",
        "australiaeast",
        "australiasoutheast",
        "brazilsouth",
        "brazilsoutheast",
