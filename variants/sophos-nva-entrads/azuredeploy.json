            "value": "[parameters('lawRetentionDays')]"
          },
          "enableVmBackup": {
            "value": "[parameters('enableVmBackup')]"
          },
          "enableAsrMgmtVm": {
            "value": "[parameters('enableAsrMgmtVm')]"
          },
          "sophosVmSize": {
            "value": "[parameters('sophosVmSize')]"
          },
          "sophosImageVersion": {
            "value": "[parameters('sophosImageVersion')]"
          },
          "enableNvaDiskBackup": {
            "value": "[parameters('enableNvaDiskBackup')]"
          },
          "entraDsSku": {
            "value": "[parameters('entraDsSku')]"
          },
          "enableSecureLdap": {
            "value": "[parameters('enableSecureLdap')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
