{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "Espria-LZ-ARM-Builder",
      "version": "3.1.0"
    },
    "displayName": "Espria LZ \u2013 A (Entra DS): Hub-Spoke + Sophos XG NVA + Entra DS",
    "description": "Hub-spoke VNet with Sophos XG NVA (BYOL). Microsoft Entra Domain Services (PaaS managed domain). Domain must be routable."
  },
  "parameters": {
    "customerName": {
      "type": "string",
      "metadata": {
        "description": "Customer full name (e.g. Contoso Ltd)"
      }
    },
    "customerAbbreviation": {
      "type": "string",
      "metadata": {
        "description": "3\u20135 character abbreviation used in all resource names (e.g. CON)"
      },
      "maxLength": 5
    },
    "customerDomainName": {
      "type": "string",
      "metadata": {
        "description": "Managed domain name. Must be routable (e.g. aadds.contoso.com). .local is NOT supported."
      }
    },
    "primaryRegion": {
      "type": "string",
      "metadata": {
        "description": "Primary Azure region."
      },
      "allowedValues": [
        "australiacentral",
        "australiacentral2",
        "australiaeast",
        "australiasoutheast",
        "brazilsouth",
