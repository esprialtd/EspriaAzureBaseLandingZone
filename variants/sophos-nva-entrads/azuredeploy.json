        "germanynorth",
        "germanywestcentral",
        "israelcentral",
        "italynorth",
        "japaneast",
        "japanwest",
        "jioindiacentral",
        "jioindiawest",
        "koreacentral",
        "koreasouth",
        "mexicocentral",
        "newzealandnorth",
        "northcentralus",
        "northeurope",
        "norwayeast",
        "norwaywest",
        "polandcentral",
        "qatarcentral",
        "southafricanorth",
        "southafricawest",
        "southcentralus",
        "southeastasia",
        "southindia",
        "spaincentral",
        "swedencentral",
        "swedensouth",
        "switzerlandnorth",
        "switzerlandwest",
        "uaecentral",
        "uaenorth",
        "uksouth",
        "ukwest",
        "westcentralus",
        "westeurope",
        "westindia",
        "westus",
        "westus2",
        "westus3"
      ],
      "defaultValue": "auto"
    },
    "deploySecondaryRegion": {
      "type": "bool",
      "metadata": {
        "description": "Deploy secondary region."
      },
      "defaultValue": true
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Deployment environment."
      },
      "allowedValues": [
        "prod",
        "dev",
        "uat"
      ],
      "defaultValue": "prod"
    },
    "primaryRegionSiteId": {
      "type": "int",
      "metadata": {
        "description": "Primary site ID (101\u2013199). 2nd octet of 10.x.0.0/16."
      },
      "defaultValue": 101,
      "minValue": 101,
      "maxValue": 199
    },
    "secondaryRegionSiteId": {
      "type": "int",
      "metadata": {
        "description": "Secondary site ID (101\u2013199)."
      },
      "defaultValue": 102,
      "minValue": 101,
      "maxValue": 199
    },
    "onPremAddressPrefix": {
      "type": "string",
      "metadata": {
        "description": "On-premises CIDR used in UDRs."
      },
      "defaultValue": "10.1.0.0/16"
    },
    "adminUsername": {
      "type": "string",
      "metadata": {
        "description": "VM admin username."
      },
      "defaultValue": "espria-admin"
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "VM admin password (12+ chars, upper+lower+number+symbol)."
      }
    },
    "dcVmSize": {
      "type": "string",
      "metadata": {
        "description": "DC VM size."
      },
      "allowedValues": [
        "Standard_D2s_v4",
        "Standard_D4s_v4",
        "Standard_D8s_v4",
        "Standard_D2ds_v4",
        "Standard_D4ds_v4",
        "Standard_D8ds_v4",
        "Standard_D2as_v4",
        "Standard_D4as_v4",
        "Standard_D8as_v4",
        "Standard_D2s_v5",
        "Standard_D4s_v5",
        "Standard_D8s_v5",
        "Standard_D2ds_v5",
        "Standard_D4ds_v5",
        "Standard_D8ds_v5",
        "Standard_D2as_v5",
        "Standard_D4as_v5",
        "Standard_D8as_v5",
        "Standard_D2ads_v5",
        "Standard_D4ads_v5",
        "Standard_D8ads_v5",
        "Standard_D2s_v6",
        "Standard_D4s_v6",
        "Standard_D8s_v6"
      ],
      "defaultValue": "Standard_D2s_v5"
    },
    "mgmtVmSize": {
      "type": "string",
      "metadata": {
        "description": "Management VM size."
      },
      "allowedValues": [
        "Standard_B2ms",
        "Standard_B4ms",
        "Standard_B8ms",
        "Standard_D2s_v5",
        "Standard_D4s_v5"
      ],
      "defaultValue": "Standard_B2ms"
    },
    "createdBy": {
      "type": "string",
      "metadata": {
        "description": "CreatedBy tag."
      },
      "defaultValue": "Espria"
    },
    "managedBy": {
      "type": "string",
      "metadata": {
        "description": "ManagedBy tag."
      },
      "defaultValue": "Espria"
    },
    "alertEmailAddress": {
      "type": "string",
      "metadata": {
        "description": "Azure Monitor alert email."
      },
      "defaultValue": "alerts@espria.com"
    },
    "lawRetentionDays": {
      "type": "int",
      "metadata": {
        "description": "Log Analytics retention days."
      },
      "defaultValue": 90,
      "minValue": 30,
      "maxValue": 730
    },
    "enableVmBackup": {
      "type": "bool",
      "metadata": {
        "description": "Azure Backup Enhanced Policy V2 for VMs."
      },
      "defaultValue": true
    },
    "enableAsrMgmtVm": {
      "type": "bool",
      "metadata": {
        "description": "ASR A2A for Management VM."
      },
      "defaultValue": true
    },
    "sophosVmSize": {
      "type": "string",
      "metadata": {
        "description": "Sophos XG VM size."
      },
      "allowedValues": [
        "Standard_D2s_v5",
        "Standard_D4s_v5",
        "Standard_D8s_v5",
        "Standard_F2s_v2",
        "Standard_F4s_v2",
        "Standard_F8s_v2"
      ],
      "defaultValue": "Standard_D2s_v5"
    },
    "sophosImageVersion": {
      "type": "string",
      "metadata": {
        "description": "Sophos XG image version."
      },
      "defaultValue": "latest"
    },
    "enableNvaDiskBackup": {
      "type": "bool",
      "metadata": {
        "description": "Azure Disk Backup for Sophos XG NVA."
      },
      "defaultValue": true
    },
    "entraDsSku": {
      "type": "string",
      "metadata": {
        "description": "Entra DS SKU. Enterprise required for replica sets."
      },
      "allowedValues": [
        "Enterprise",
        "Standard",
        "Premium"
      ],
      "defaultValue": "Enterprise"
    },
    "enableSecureLdap": {
      "type": "bool",
      "metadata": {
        "description": "Enable Secure LDAP. Certificate required post-deployment."
      },
      "defaultValue": false
    }
  },
  "variables": {
    "deploymentName": "[concat('espria-lz-sophos-nva-entrads-', uniqueString(deployment().name))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "[variables('deploymentName')]",
      "location": "[parameters('primaryRegion')]",
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "Inner"
        },
        "parameters": {
          "customerName": {
            "value": "[parameters('customerName')]"
          },
          "customerAbbreviation": {
            "value": "[parameters('customerAbbreviation')]"
          },
          "customerDomainName": {
            "value": "[parameters('customerDomainName')]"
          },
          "primaryRegion": {
            "value": "[parameters('primaryRegion')]"
          },
          "secondaryRegion": {
            "value": "[parameters('secondaryRegion')]"
          },
          "deploySecondaryRegion": {
            "value": "[parameters('deploySecondaryRegion')]"
          },
          "environment": {
            "value": "[parameters('environment')]"
          },
          "primaryRegionSiteId": {
            "value": "[parameters('primaryRegionSiteId')]"
          },
          "secondaryRegionSiteId": {
            "value": "[parameters('secondaryRegionSiteId')]"
          },
          "onPremAddressPrefix": {
            "value": "[parameters('onPremAddressPrefix')]"
          },
          "adminUsername": {
            "value": "[parameters('adminUsername')]"
          },
          "adminPassword": {
            "value": "[parameters('adminPassword')]"
          },
          "dcVmSize": {
            "value": "[parameters('dcVmSize')]"
          },
          "mgmtVmSize": {
            "value": "[parameters('mgmtVmSize')]"
          },
          "createdBy": {
            "value": "[parameters('createdBy')]"
          },
          "managedBy": {
            "value": "[parameters('managedBy')]"
          },
          "alertEmailAddress": {
            "value": "[parameters('alertEmailAddress')]"
          },
