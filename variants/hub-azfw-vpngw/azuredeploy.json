        "westindia",
        "westus",
        "westus2",
        "westus3"
      ],
      "defaultValue": "auto"
    },
    "deploySecondaryRegion": {
      "type": "bool",
      "metadata": {
        "description": "Deploy resources into the secondary region. Set to false for primary-only."
      },
      "defaultValue": true
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Deployment environment tag."
      },
      "allowedValues": [
        "prod",
        "dev",
        "uat"
      ],
      "defaultValue": "prod"
    },
    "primaryRegionSiteId": {
      "type": "int",
      "metadata": {
        "description": "Primary region site ID (101\u2013199). Used as 2nd octet of 10.x.0.0/16."
      },
      "defaultValue": 101,
      "minValue": 101,
      "maxValue": 199
    },
    "secondaryRegionSiteId": {
      "type": "int",
      "metadata": {
        "description": "Secondary region site ID (101\u2013199). Used as 2nd octet of 10.x.0.0/16."
      },
      "defaultValue": 102,
      "minValue": 101,
      "maxValue": 199
    },
    "onPremAddressPrefix": {
      "type": "string",
      "metadata": {
        "description": "On-premises address prefix used in spoke UDRs (e.g. 10.1.0.0/16)."
      },
      "defaultValue": "10.1.0.0/16"
    },
    "adminUsername": {
      "type": "string",
      "metadata": {
        "description": "Local administrator username for all VMs."
      },
      "defaultValue": "espria-admin"
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "VM admin password. Minimum 12 characters with upper, lower, number and symbol."
      }
    },
    "dcVmSize": {
      "type": "string",
      "metadata": {
        "description": "Domain Controller VM size."
      },
      "allowedValues": [
        "Standard_D2s_v4",
        "Standard_D4s_v4",
        "Standard_D8s_v4",
        "Standard_D2ds_v4",
        "Standard_D4ds_v4",
        "Standard_D8ds_v4",
        "Standard_D2as_v4",
        "Standard_D4as_v4",
        "Standard_D8as_v4",
        "Standard_D2s_v5",
        "Standard_D4s_v5",
        "Standard_D8s_v5",
        "Standard_D2ds_v5",
        "Standard_D4ds_v5",
        "Standard_D8ds_v5",
        "Standard_D2as_v5",
        "Standard_D4as_v5",
        "Standard_D8as_v5",
        "Standard_D2ads_v5",
        "Standard_D4ads_v5",
        "Standard_D8ads_v5",
        "Standard_D2s_v6",
        "Standard_D4s_v6",
        "Standard_D8s_v6"
      ],
      "defaultValue": "Standard_D2s_v5"
    },
    "mgmtVmSize": {
      "type": "string",
      "metadata": {
        "description": "Management jump VM size."
      },
      "allowedValues": [
        "Standard_B2ms",
        "Standard_B4ms",
        "Standard_B8ms",
        "Standard_D2s_v5",
        "Standard_D4s_v5"
      ],
      "defaultValue": "Standard_B2ms"
    },
    "createdBy": {
      "type": "string",
      "metadata": {
        "description": "Tag value for CreatedBy. Identifies who deployed this Landing Zone."
      },
      "defaultValue": "Espria"
    },
    "managedBy": {
      "type": "string",
      "metadata": {
        "description": "Tag value for ManagedBy. Identifies the managing party."
      },
      "defaultValue": "Espria"
    },
    "alertEmailAddress": {
      "type": "string",
      "metadata": {
        "description": "Email address for Azure Monitor Action Group alerts (Espria NOC)."
      },
      "defaultValue": "alerts@espria.com"
    },
    "lawRetentionDays": {
      "type": "int",
      "metadata": {
        "description": "Log Analytics Workspace retention in days."
      },
      "defaultValue": 90,
      "minValue": 30,
      "maxValue": 730
    },
    "enableVmBackup": {
      "type": "bool",
      "metadata": {
        "description": "Enable Azure Backup Enhanced Policy V2 for DC VMs and the Management VM."
      },
      "defaultValue": true
    },
    "enableAsrMgmtVm": {
      "type": "bool",
      "metadata": {
        "description": "Enable Azure Site Recovery A2A replication for the Management VM (primary to secondary)."
      },
      "defaultValue": true
    },
    "firewallSkuTier": {
      "type": "string",
      "metadata": {
        "description": "Azure Firewall SKU tier. Premium enables IDPS and TLS inspection. Standard is lower cost."
      },
      "allowedValues": [
        "Premium",
        "Standard"
      ],
      "defaultValue": "Premium"
    },
    "vpnGwSku": {
      "type": "string",
      "metadata": {
        "description": "VPN Gateway SKU. VpnGw1AZ is zone-redundant and supports active-active with BGP. Use VpnGw2AZ or VpnGw3AZ for higher throughput."
      },
      "allowedValues": [
        "VpnGw1AZ",
        "VpnGw2AZ",
        "VpnGw3AZ",
        "VpnGw1",
        "VpnGw2",
        "VpnGw3"
      ],
      "defaultValue": "VpnGw1AZ"
    },
    "bgpAsn": {
      "type": "int",
      "metadata": {
        "description": "BGP Autonomous System Number for the Azure VPN Gateway. Must differ from your on-premises ASN. Azure reserved ranges 65515\u201365534 must not be used."
      },
      "defaultValue": 65000,
      "minValue": 1,
      "maxValue": 65534
    },
    "enableNvaDiskBackup": {
      "type": "bool",
      "metadata": {
        "description": "Enable NVA disk backup. Always false for this variant \u2013 no NVA is deployed."
      },
      "defaultValue": false
    }
  },
  "variables": {
    "deploymentName": "[concat('espria-lz-hub-azfw-vpngw-', uniqueString(deployment().name))]"
  },
