{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "Espria-LZ-ARM-Builder",
      "version": "3.0.0"
    },
    "displayName": "Espria LZ \u2013 Variant C: Hub-Spoke + Azure Firewall + Active-Active VPN Gateway",
    "description": "Deploys the Espria Azure Base Landing Zone using hub-spoke VNet architecture with Azure Firewall Premium and an active-active zone-redundant VPN Gateway (VpnGw1AZ, BGP enabled). Spoke UDRs route all traffic to the Azure Firewall private IP. IaaS Active Directory Domain Controllers. Azure Backup Enhanced Policy V2. Azure Site Recovery for the Management VM."
  },
  "parameters": {
    "customerName": {
      "type": "string",
      "metadata": {
        "description": "Customer full name (e.g. Contoso Ltd)"
      }
    },
    "customerAbbreviation": {
      "type": "string",
      "metadata": {
        "description": "3\u20135 character abbreviation used in all resource names (e.g. CON)"
      },
      "maxLength": 5
    },
    "customerDomainName": {
      "type": "string",
      "metadata": {
        "description": "Active Directory domain name (e.g. contoso.local)"
      }
    },
    "primaryRegion": {
      "type": "string",
      "metadata": {
        "description": "Primary Azure region for the Landing Zone"
      },
      "allowedValues": [
        "australiacentral",
